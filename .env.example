# Moire Tracker v2 Configuration
# Copy this file to .env and fill in your values

# ==========================================
# OpenAI API (optional - for CNN classification)
# ==========================================
OPENAI_API_KEY=sk-your-api-key-here

# ==========================================
# Server Configuration
# ==========================================
MOIRE_PORT=8765
MOIRE_HOST=localhost

# ==========================================
# Detection Settings
# ==========================================
# Output directory for detection results
MOIRE_OUTPUT_DIR=./detection_results

# ==========================================
# Feature Toggles
# ==========================================
# Set to 'false' to disable
MOIRE_ENABLE_OCR=true
MOIRE_ENABLE_CNN=true
MOIRE_ENABLE_STREAMING=true

# ==========================================
# OCR Settings
# ==========================================
# Tesseract languages (comma-separated)
MOIRE_OCR_LANGUAGES=eng,deu
# Minimum confidence threshold (0-1)
MOIRE_OCR_MIN_CONFIDENCE=0.4

# ==========================================
# Streaming Settings
# ==========================================
# Interval between captures in ms
MOIRE_STREAM_INTERVAL=2000